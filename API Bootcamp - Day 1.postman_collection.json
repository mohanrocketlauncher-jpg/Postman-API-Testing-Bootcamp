    {
      "name": "https://httpbin.org/post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseData = pm.response.json();\r",
              "const expectedName = pm.variables.get(\"variable_name\");\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Check if Name matches\", function () {\r",
              "    // We check if the response name equals our variable\r",
              "    pm.expect(responseData.json.name).to.eql(expectedName);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// This creates the random name and saves it to a variable\r",
              "const randomName = \"User_\" + Math.random().toString(36).substring(7);\r",
              "pm.variables.set(\"variable_name\", randomName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{variable_name}}\",\r\n    \"course\": \"Postman Intensive\",\r\n    \"day\": 1,\r\n    \"status\": \"learning\"\r\n}",
          "options": {
