    {
      "name": "https://postman-echo.com/post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. We create our own \"Data File\" right here for free\r",
              "const userPool = [\r",
              "    { \"user\": \"postman\", \"pass\": \"password\" },\r",
              "    { \"user\": \"hacker\", \"pass\": \"wrong_pass\" },\r",
              "    { \"user\": \"mohan\", \"pass\": \"secret123\" }\r",
              "];\r",
              "\r",
              "// 2. We pick one randomly or just use the first one for now\r",
              "let randomUser = userPool[Math.floor(Math.random() * userPool.length)];\r",
              "\r",
              "// 3. We set the variables manually so the Body can see them\r",
              "pm.variables.set(\"username\", randomUser.user);\r",
              "pm.variables.set(\"password\", randomUser.pass);\r",
              "\r",
              "console.log(\"Testing with User: \" + randomUser.user);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"{{username}}\",\r\n  \"password\": \"{{password}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://postman-echo.com/post",
          "protocol": "https",
          "host": [
            "postman-echo",
