    {
      "name": "https://postman-echo.com/basic-auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// We EXPECT a 401 because we sent a bad password\r",
              "pm.test(\"Security Check: Access should be denied\", function () {\r",
              "    pm.response.to.have.status(401);\r",
              "});\r",
              "\r",
              "// We want to make sure the body says \"Unauthorized\"\r",
              "pm.test(\"Error message is correct\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Unauthorized\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
